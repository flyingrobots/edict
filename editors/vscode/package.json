{
  "name": "edict-vscode",
  "displayName": "Edict",
  "description": "Syntax highlighting for Edict source files.",
  "version": "0.6.0-alpha.1",
  "publisher": "flyingrobots",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/flyingrobots/edict.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "edict",
    "syntax",
    "highlighting"
  ],
  "contributes": {
    "languages": [
      {
        "id": "edict",
        "aliases": [
          "Edict",
          "edict"
        ],
        "extensions": [
          ".edict"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "edict",
        "scopeName": "source.edict",
        "path": "./syntaxes/edict.tmLanguage.json"
      }
    ]
  }
}
