{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flyingrobots.dev/schemas/edict/cli-check-result/v1",
  "title": "Edict CLI Check Result v1",
  "description": "JSONL success result record emitted to stdout when an input checks clean.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "type", "command", "input", "status"],
  "properties": {
    "schema": {
      "const": "edict.cli.check-result/v1"
    },
    "type": {
      "const": "checkResult"
    },
    "command": {
      "const": "check"
    },
    "input": {
      "$ref": "#/$defs/inputDescriptor"
    },
    "status": {
      "const": "ok"
    }
  },
  "$defs": {
    "inputDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    }
  }
}
